<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="À l'écoute..."
        android:textSize="16sp" />

    <TextView
        android:id="@+id/transfers_count_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="0 transfert(s) en attente"
        android:textSize="14sp" />

    <Button
        android:id="@+id/start_listening_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/start_listening" />

    <Button
        android:id="@+id/stop_listening_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/stop_listening" />

</LinearLayout>
